<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.campus.post.mapper.CampusPostCommentMapper">

    <resultMap id="CommentResult" type="com.ruoyi.campus.post.domain.CampusPostComment">
        <id     property="commentId"  column="comment_id"/>
        <result property="postId"     column="post_id"/>
        <result property="authorId"   column="author_id"/>
        <result property="authorName" column="author_name"/>
        <result property="content"    column="content"/>
        <result property="parentId"   column="parent_id"/>
        <result property="createTime" column="create_time"/>
    </resultMap>

    <sql id="selectCommentVo">
        SELECT c.*, u.nick_name AS author_name
        FROM campus_post_comment c
                 LEFT JOIN sys_user u ON u.user_id = c.author_id
        WHERE c.del_flag = '0'
    </sql>

    <select id="selectCommentsByPostId" resultMap="CommentResult">
        <include refid="selectCommentVo"/>
        AND c.post_id = #{postId}
        AND c.parent_id = 0
        ORDER BY c.create_time ASC
    </select>

    <select id="selectChildrenByParentId" resultMap="CommentResult">
        <include refid="selectCommentVo"/>
        AND c.parent_id = #{parentId}
        ORDER BY c.create_time ASC
    </select>

</mapper>