<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.campus.post.mapper.CampusPostMapper">

    <resultMap id="PostResult" type="com.ruoyi.campus.post.domain.CampusPost">
        <id     property="postId"      column="post_id"/>
        <result property="title"       column="title"/>
        <result property="content"     column="content"/>
        <result property="authorId"    column="author_id"/>
        <result property="authorName"  column="author_name"/>
        <result property="category"    column="category"/>
        <result property="viewCount"   column="view_count"/>
        <result property="likeCount"   column="like_count"/>
        <result property="status"      column="status"/>
        <result property="createTime"  column="create_time"/>
    </resultMap>

    <sql id="selectPostVo">
        SELECT p.*, u.nick_name AS author_name
        FROM campus_post p
                 LEFT JOIN sys_user u ON u.user_id = p.author_id
        WHERE p.del_flag = '0'
    </sql>

    <select id="selectPostList" resultMap="PostResult">
        <include refid="selectPostVo"/>
        <if test="title != null and title != ''">
            AND p.title LIKE CONCAT('%', #{title}, '%')
        </if>
        <if test="category != null and category != ''">
            AND p.category = #{category}
        </if>
        <if test="status != null and status != ''">
            AND p.status = #{status}
        </if>
        ORDER BY p.create_time DESC
    </select>

    <select id="selectPostById" resultMap="PostResult">
        <include refid="selectPostVo"/>
        AND p.post_id = #{postId}
    </select>

</mapper>