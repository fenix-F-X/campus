<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.campus.task.mapper.CampusTaskMapper">

    <resultMap id="TaskResult" type="com.ruoyi.campus.task.domain.CampusTask">
        <id     property="taskId"       column="task_id"/>
        <result property="title"        column="title"/>
        <result property="content"      column="content"/>
        <result property="publisherId"  column="publisher_id"/>
        <result property="deptId"       column="dept_id"/>
        <result property="status"       column="status"/>
        <result property="rewardPoints" column="reward_points"/>
        <result property="deadline"     column="deadline"/>
        <result property="createTime"   column="create_time"/>

        <result property="publisherName" column="publisher_name"/>
    </resultMap>

    <sql id="selectTaskVo">
        SELECT t.*, u.nick_name AS publisher_name
        FROM campus_task t
                 LEFT JOIN sys_user u ON u.user_id = t.publisher_id
        WHERE t.del_flag = '0'
    </sql>

    <select id="selectTaskList" resultMap="TaskResult">
        <include refid="selectTaskVo"/><if test="title != null and title != ''">
        AND t.title LIKE CONCAT('%', #{title}, '%')
    </if>
        <if test="status != null and status != ''">
            AND t.status = #{status}
        </if>
        <if test="publisherId != null">
            AND t.publisher_id = #{publisherId}
        </if>
        ORDER BY t.create_time DESC
    </select>

    <select id="selectAvailableTasks" resultMap="TaskResult">
        <include refid="selectTaskVo"/>
        AND t.status = '0'
        AND t.task_id NOT IN (
        SELECT task_id FROM campus_task_record WHERE taker_id = #{userId}
        )
        ORDER BY t.create_time DESC
    </select>



</mapper>