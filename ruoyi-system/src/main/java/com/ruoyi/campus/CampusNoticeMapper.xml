<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.campus.notice.mapper.CampusNoticeMapper">

    <resultMap id="NoticeResult" type="com.ruoyi.campus.notice.domain.CampusNotice">
        <id     property="noticeId"      column="notice_id"/>
        <result property="title"         column="title"/>
        <result property="content"       column="content"/>
        <result property="type"          column="type"/>
        <result property="publisherId"   column="publisher_id"/>
        <result property="publisherName" column="publisher_name"/>
        <result property="viewCount"     column="view_count"/>
        <result property="isTop"         column="is_top"/>
        <result property="status"        column="status"/>
        <result property="createTime"    column="create_time"/>
    </resultMap>

    <sql id="selectNoticeVo">
        SELECT n.*, u.nick_name AS publisher_name
        FROM campus_notice n
                 LEFT JOIN sys_user u ON u.user_id = n.publisher_id
        WHERE n.del_flag = '0'
    </sql>

    <select id="selectNoticeList" resultMap="NoticeResult">
        <include refid="selectNoticeVo"/>
        <if test="title != null and title != ''">
            AND n.title LIKE CONCAT('%', #{title}, '%')
        </if>
        <if test="type != null and type != ''">
            AND n.type = #{type}
        </if>
        <if test="status != null and status != ''">
            AND n.status = #{status}
        </if>
        <if test="isTop != null and isTop != ''">
            AND n.is_top = #{isTop}
        </if>
        ORDER BY n.is_top DESC, n.create_time DESC
    </select>

</mapper>